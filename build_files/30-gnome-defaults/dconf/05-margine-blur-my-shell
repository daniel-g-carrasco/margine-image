# blur-my-shell defaults.
#
# 2026-06-16: blur-my-shell is NO LONGER in Margine's default enabled set
# (see build_files/30-gnome-defaults/install.sh, zz1 enabled-extensions). It
# was dropped because on the reference HiDPI iGPU (2880x1920@120Hz, Radeon
# 760M) its DYNAMIC per-frame Gaussian blur (sigma=70 at scale 2 ≈ 420 taps/
# px/frame) blew the 8.3ms frame budget and made BOTH its own view
# transitions AND o-tiling window animations visibly janky — verified live
# ("without blur everything runs smoother"). It also carries three known,
# open, unfixed-upstream defects on GNOME 50: black background on monitor
# hotplug (aunetx/blur-my-shell#561), ghost app-grid icons during the
# overview swipe (#738, the Shell.BlurEffect non-repaint bug GNOME#2857),
# and unreliable dynamic dock-blur capture (#574). The extension stays
# INSTALLED (Bluefin ships it), so a user can re-enable it per session.
#
# These values are the SMOOTH, SAFE defaults that apply IF a user re-enables
# it: static blur everywhere always-on (computed once against the wallpaper,
# ~free per frame — NOT recomputed every frame like dynamic), a much lower
# sigma, and overview blur OFF (the swipe-ghost source). This way re-enabling
# never reintroduces the jank or the ghost artifacts that got it dropped.

[org/gnome/shell/extensions/blur-my-shell/appfolder]
brightness=0.4
sigma=48

[org/gnome/shell/extensions/blur-my-shell/applications]
pipeline='pipeline_default'

[org/gnome/shell/extensions/blur-my-shell/coverflow-alt-tab]
pipeline='pipeline_default'

[org/gnome/shell/extensions/blur-my-shell/dash-to-dock]
blur=true
brightness=0.4
pipeline='pipeline_default_rounded'
sigma=30
static-blur=true
style-dash-to-dock=0
unblur-in-overview=true

[org/gnome/shell/extensions/blur-my-shell/dash-to-panel]
blur-original-panel=true

[org/gnome/shell/extensions/blur-my-shell/lockscreen]
pipeline='pipeline_default'

[org/gnome/shell/extensions/blur-my-shell/overview]
blur=false
pipeline='pipeline_default'

[org/gnome/shell/extensions/blur-my-shell/panel]
brightness=0.4
corner-radius=0
override-background=true
pipeline='pipeline_default'
sigma=30
static-blur=true
unblur-in-overview=true

[org/gnome/shell/extensions/blur-my-shell/screenshot]
pipeline='pipeline_default'

[org/gnome/shell/extensions/blur-my-shell/window-list]
brightness=0.4
sigma=48
