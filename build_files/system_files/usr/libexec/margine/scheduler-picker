#!/usr/bin/gjs -m
// Margine CPU Scheduler — a GTK4 / libadwaita front-end for the sched_ext
// (BPF) opt-in flow. Native GNOME UI over scxctl + scx_loader that explains,
// per scheduler, what it is good for, exposes the scx_loader modes, applies on
// tap, and persists the choice so it actually survives a reboot.
//
// Backend (verified against scxctl 1.1.1 / scx_loader on Margine):
//   - `scxctl list`                         -> supported schedulers
//   - `scxctl get`                          -> "running Lavd in Auto mode" / "no scx scheduler running"
//   - `scxctl start|switch --sched NAME --mode MODE`   (user, D-Bus to loader)
//   - `scxctl stop`                                     (user)
//   CLI mode values are lowercase: auto gaming lowlatency powersave server.
//
// Persistence (the bit scxctl alone does NOT do): scx_loader only restores a
// scheduler on boot if /etc/scx_loader/config.toml sets default_sched /
// default_mode. So Apply also writes that file (PascalCase mode, scx_ prefix)
// and enables the service; Reset removes it and disables the service. That
// write + enable is the only privileged step -> one polkit (pkexec) prompt.

import GObject from "gi://GObject";
import Gio from "gi://Gio";
import GLib from "gi://GLib";
import Gtk from "gi://Gtk?version=4.0";
import Adw from "gi://Adw?version=1";
import system from "system";

const APP_ID = "org.margineos.SchedulerPicker";
const SERVICE = "scx_loader.service";
const CONFIG = "/etc/scx_loader/config.toml";
// All privileged work goes through this one helper so a scoped polkit rule
// (49-margine-scheduler.rules) can ask once per session instead of every time.
const HELPER = "/usr/libexec/margine/scheduler-apply";

// scx_loader modes. cli = scxctl --mode value (lowercase); conf = TOML
// default_mode value (PascalCase enum); label = UI text.
const MODES = [
  { id: "auto", cli: "auto", conf: "Auto", label: "Auto" },
  { id: "gaming", cli: "gaming", conf: "Gaming", label: "Gaming" },
  { id: "lowlatency", cli: "lowlatency", conf: "LowLatency", label: "Low latency" },
  { id: "powersave", cli: "powersave", conf: "PowerSave", label: "Power save" },
  { id: "server", cli: "server", conf: "Server", label: "Server" },
];
const modeById = (id) => MODES.find((m) => m.id === id) || MODES[0];

// Honest, practical descriptions for the schedulers we know well; anything else
// scxctl reports gets the GENERIC note rather than an invented use-case.
const META = {
  lavd: {
    tag: "Gaming & low latency",
    blurb:
      "Latency-Aware Virtual Deadline. Keeps games, real-time audio and the " +
      "desktop responsive while heavy work runs in the background. Margine's " +
      "recommended pick for gaming.",
    star: true,
  },
  bpfland: {
    tag: "Interactive desktop",
    blurb:
      "Balances responsiveness and throughput. A strong all-day default — " +
      "browsers, editors and video calls stay smooth under load.",
    star: true,
  },
  flash: {
    tag: "Audio & real-time",
    blurb:
      "Earliest-deadline-first for predictable latency. Best for pro-audio " +
      "(DAWs, low-buffer PipeWire/JACK) and other deadline-sensitive work.",
  },
  rusty: {
    tag: "Balanced multi-core",
    blurb:
      "General-purpose, multi-domain. A safe balanced choice for mixed " +
      "workloads on many-core machines — builds, VMs, containers.",
  },
  cosmos: {
    tag: "General purpose",
    blurb:
      "Broad workload coverage with sane defaults. A good neutral choice when " +
      "you are not sure which to pick.",
  },
  p2dq: {
    tag: "Throughput & servers",
    blurb:
      "Per-CPU scheduler with two deadline queues. Leans toward throughput and " +
      "scales well on high core counts and server-style loads.",
  },
  tickless: {
    tag: "Power & virtualization",
    blurb:
      "Minimises timer ticks for fewer wakeups — useful for battery life, VM " +
      "hosts and latency-isolated cores.",
  },
  rustland: {
    tag: "Experimental (userspace)",
    blurb:
      "Scheduling logic runs in userspace (Rust). Great for experimenting with " +
      "sched_ext; not aimed at peak performance.",
  },
};
const GENERIC = {
  tag: "Experimental",
  blurb:
    "An additional sched_ext scheduler from the scx project. Worth a try if you " +
    "like to experiment — see the scx documentation for specifics.",
};
const PREFERRED = ["lavd", "bpfland", "flash", "rusty", "cosmos", "p2dq", "tickless", "rustland"];

// Run a command synchronously; return { ok, out } with stdout+stderr merged.
function run(argv) {
  try {
    const proc = Gio.Subprocess.new(
      argv,
      Gio.SubprocessFlags.STDOUT_PIPE | Gio.SubprocessFlags.STDERR_MERGE,
    );
    const [, out] = proc.communicate_utf8(null, null);
    return { ok: proc.get_successful(), out: out ?? "" };
  } catch (e) {
    return { ok: false, out: `${e}` };
  }
}

function listSchedulers() {
  const { out } = run(["scxctl", "list"]);
  const names = [...out.matchAll(/"([^"]+)"/g)].map((m) => m[1]);
  const ordered = PREFERRED.filter((n) => names.includes(n));
  for (const n of names) if (!ordered.includes(n)) ordered.push(n);
  return ordered;
}

// Independent system check: ask scxctl what is running. Output is e.g.
// "running Lavd in Auto mode" — name + mode capitalized, no scx_ prefix.
function currentState(supported) {
  const { out } = run(["scxctl", "get"]);
  if (!out.trim() || /no scx scheduler running/i.test(out)) return { sched: "off", mode: "auto" };
  const m = out.match(/running\s+(?:scx[_-])?(\S+)\s+in\s+(\S+)\s+mode/i);
  if (m) {
    const stok = m[1].toLowerCase();
    const mtok = m[2].toLowerCase();
    const sched = supported.find((n) => n.toLowerCase() === stok) || "unknown";
    const mode = (MODES.find((x) => x.conf.toLowerCase() === mtok) || {}).id || "auto";
    return { sched, mode };
  }
  for (const n of supported) {
    if (new RegExp(`(^|[^a-z0-9_])(scx[_-])?${n}([^a-z0-9_]|$)`, "i").test(out))
      return { sched: n, mode: "auto" };
  }
  return { sched: "unknown", mode: "auto" };
}

function loaderState() {
  return {
    active: run(["systemctl", "is-active", SERVICE]).out.trim() || "unknown",
    enabled: run(["systemctl", "is-enabled", SERVICE]).out.trim() || "unknown",
  };
}

// What scx_loader will start on boot (the real persistence signal).
function bootDefault() {
  const { out } = run(["cat", CONFIG]);
  const sched = (out.match(/^\s*default_sched\s*=\s*"?(\S+?)"?\s*$/m) || [])[1] || null;
  const mode = (out.match(/^\s*default_mode\s*=\s*"?(\S+?)"?\s*$/m) || [])[1] || null;
  return { sched, mode };
}

function osPretty() {
  const { out } = run(["cat", "/etc/os-release"]);
  return (out.match(/^PRETTY_NAME="?(.*?)"?\s*$/m) || [])[1] || "Margine";
}

const SchedulerWindow = GObject.registerClass(
  class SchedulerWindow extends Adw.ApplicationWindow {
    _init(app) {
      super._init({
        application: app,
        title: "CPU Scheduler",
        default_width: 560,
        default_height: 760,
        width_request: 360,
        height_request: 480,
      });

      this._rows = new Map(); // name -> { row, tick }
      this._mode = "auto";
      this._suppressMode = false;

      const css = new Gtk.CssProvider();
      css.load_from_string(".scheduler-active { background-color: alpha(@accent_color, 0.13); }");
      Gtk.StyleContext.add_provider_for_display(
        this.get_display(),
        css,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
      );

      this._installActions(app);

      this._toasts = new Adw.ToastOverlay();
      const toolbar = new Adw.ToolbarView();
      this._toasts.set_child(toolbar);
      this.set_content(this._toasts);

      const header = new Adw.HeaderBar();
      toolbar.add_top_bar(header);
      const refreshBtn = new Gtk.Button({
        icon_name: "view-refresh-symbolic",
        tooltip_text: "Re-check the active scheduler (F5)",
        action_name: "app.refresh",
      });
      header.pack_start(refreshBtn);
      const menu = new Gio.Menu();
      menu.append("Re-check now", "app.refresh");
      menu.append("Reset to kernel default (BORE)", "app.reset");
      menu.append("About Margine CPU Scheduler", "app.about");
      header.pack_end(
        new Gtk.MenuButton({ icon_name: "open-menu-symbolic", menu_model: menu, primary: true }),
      );

      const page = new Adw.PreferencesPage();
      toolbar.set_content(page);

      // --- "Active now": live cross-check + mode + one-tap reset.
      const statusGroup = new Adw.PreferencesGroup({ title: "Active now" });
      page.add(statusGroup);

      this._statusIcon = Gtk.Image.new_from_icon_name("dialog-question-symbolic");
      this._statusIcon.add_css_class("dim-label");
      this._statusRow = new Adw.ActionRow({ title: "Checking…", subtitle: "" });
      this._statusRow.add_prefix(this._statusIcon);
      statusGroup.add(this._statusRow);

      const modeModel = new Gtk.StringList();
      for (const m of MODES) modeModel.append(m.label);
      this._modeRow = new Adw.ComboRow({
        title: "Mode",
        subtitle: "Auto adapts (recommended); the rest force a profile",
        model: modeModel,
      });
      this._modeRow.connect("notify::selected", () => this._onModeChanged());
      statusGroup.add(this._modeRow);

      this._resetRow = new Adw.ButtonRow({
        title: "Reset to kernel default (BORE)",
        start_icon_name: "edit-undo-symbolic",
      });
      this._resetRow.connect("activated", () => this._apply("off"));
      statusGroup.add(this._resetRow);

      // --- "Choose a scheduler": tap a row to switch (one polkit prompt).
      this._group = new Adw.PreferencesGroup({
        title: "Choose a scheduler",
        description:
          "Margine runs a signed CachyOS/BORE kernel with pluggable sched_ext " +
          "(BPF) schedulers. Tap one to switch to it — it applies live (no " +
          "reboot) and is saved as the boot default.",
      });
      page.add(this._group);

      const foot = new Adw.PreferencesGroup();
      const note = new Adw.ActionRow({
        title: "Prefer a terminal?",
        subtitle: "Run “ujust margine-scheduler NAME” — same effect as this app.",
        subtitle_selectable: true,
      });
      note.add_prefix(Gtk.Image.new_from_icon_name("utilities-terminal-symbolic"));
      foot.add(note);
      page.add(foot);

      this._populate();
      this._refresh();

      // Live auto-refresh so the status stays correct if the scheduler is
      // changed from elsewhere (CLI, ujust). Read-only; stops with the window.
      this._timer = GLib.timeout_add_seconds(GLib.PRIORITY_DEFAULT, 4, () => {
        this._refresh();
        return GLib.SOURCE_CONTINUE;
      });
      this.connect("close-request", () => {
        if (this._timer) GLib.source_remove(this._timer);
        this._timer = 0;
        return false;
      });
    }

    _installActions(app) {
      const add = (name, fn, accels) => {
        if (!app.lookup_action(name)) {
          const a = new Gio.SimpleAction({ name });
          a.connect("activate", fn);
          app.add_action(a);
        }
        if (accels) app.set_accels_for_action(`app.${name}`, accels);
      };
      add("refresh", () => this._refresh(), ["F5", "<Control>r"]);
      add("reset", () => this._apply("off"), ["<Control>0"]);
      add("about", () => this._showAbout(), ["F1"]);
      add("quit", () => app.quit(), ["<Control>q", "<Control>w"]);
    }

    _populate() {
      const supported = listSchedulers();
      if (supported.length === 0) {
        this._group.add(
          new Adw.ActionRow({
            title: "No schedulers available",
            subtitle: "scxctl reported nothing — is the scx-scheds package installed?",
          }),
        );
        return;
      }
      for (const name of supported) {
        const meta = META[name] ?? GENERIC;
        this._addSchedulerRow(name, meta);
      }
    }

    _addSchedulerRow(name, meta) {
      const row = new Adw.ActionRow({
        title: meta.star ? `scx_${name}  ★` : `scx_${name}`,
        subtitle: meta.blurb,
        activatable: true,
      });
      const badge = new Gtk.Label({ label: meta.tag, valign: Gtk.Align.CENTER });
      badge.add_css_class("dim-label");
      badge.add_css_class("caption");
      row.add_suffix(badge);

      const tick = Gtk.Image.new_from_icon_name("object-select-symbolic");
      tick.add_css_class("success");
      tick.set_visible(false);
      row.add_suffix(tick);

      row.connect("activated", () => this._apply(name));
      this._group.add(row);
      this._rows.set(name, { row, tick });
    }

    _onModeChanged() {
      if (this._suppressMode) return;
      const mode = (MODES[this._modeRow.selected] || MODES[0]).id;
      if (mode === this._mode) return;
      this._mode = mode;
      const cur = currentState([...this._rows.keys()]);
      if (cur.sched !== "off" && cur.sched !== "unknown") this._apply(cur.sched, mode);
    }

    _refresh() {
      const supported = [...this._rows.keys()];
      const st = currentState(supported);
      const { active: svc, enabled } = loaderState();
      const boot = bootDefault();

      for (const [name, { row, tick }] of this._rows) {
        const on = name === st.sched;
        tick.set_visible(on);
        if (on) row.add_css_class("scheduler-active");
        else row.remove_css_class("scheduler-active");
      }
      this._resetRow.set_sensitive(st.sched !== "off");

      this._mode = st.mode;
      const idx = MODES.findIndex((m) => m.id === st.mode);
      this._suppressMode = true;
      this._modeRow.selected = idx >= 0 ? idx : 0;
      this._suppressMode = false;

      const bootText = boot.sched
        ? `${boot.sched}${boot.mode ? ` / ${boot.mode}` : ""}`
        : "kernel default (BORE)";

      this._statusIcon.remove_css_class("success");
      this._statusIcon.remove_css_class("dim-label");
      if (st.sched === "off") {
        this._statusIcon.icon_name = "system-shutdown-symbolic";
        this._statusIcon.add_css_class("dim-label");
        this._statusRow.title = "Kernel default (BORE)";
        this._statusRow.subtitle = `Live check · sched_ext off · on boot: ${bootText}`;
      } else if (st.sched === "unknown") {
        this._statusIcon.icon_name = "dialog-warning-symbolic";
        this._statusRow.title = "A scheduler is running";
        this._statusRow.subtitle = `Live check · name not recognised · ${SERVICE} ${svc}`;
      } else {
        this._statusIcon.icon_name = "object-select-symbolic";
        this._statusIcon.add_css_class("success");
        this._statusRow.title = `scx_${st.sched} · ${modeById(st.mode).label}`;
        this._statusRow.subtitle = `Live check · ${SERVICE} ${svc}, ${enabled} · on boot: ${bootText}`;
      }
    }

    _toast(text) {
      this._toasts.add_toast(new Adw.Toast({ title: text, timeout: 4 }));
    }

    _showAbout() {
      const pretty = osPretty();
      const kernel = run(["uname", "-r"]).out.trim();
      const scxver = run(["scxctl", "--version"]).out.trim();
      const about = new Adw.AboutDialog({
        application_name: "Margine CPU Scheduler",
        application_icon: "margine-scheduler",
        version: pretty.replace(/^Margine\s*/, "") || "alpha",
        developer_name: "Margine",
        website: "https://margine.dev",
        issue_url: "https://github.com/daniel-g-carrasco/margine-image/issues",
        license_type: Gtk.License.APACHE_2_0,
        comments:
          "Switch the kernel's sched_ext (BPF) CPU scheduler at runtime.\n\n" +
          `${pretty}\nKernel ${kernel} · ${scxver}`,
      });
      about.present(this);
    }

    // Apply a scheduler (with mode) or "off" through the one privileged helper
    // (config + service + live switch) — a single pkexec, asked once per session
    // thanks to the scoped polkit rule.
    _apply(name, mode) {
      const m = modeById(mode ?? this._mode);
      const result =
        name === "off"
          ? run(["pkexec", HELPER, "off"])
          : run(["pkexec", HELPER, name, m.conf, m.cli]);

      this._refresh();
      if (result.ok) {
        this._toast(
          name === "off"
            ? "Reverted to the kernel default (BORE)"
            : `Now running scx_${name} (${m.label.replace(/ \(recommended\)$/, "")})`,
        );
      } else {
        const msg = (result.out || "").trim().split("\n").pop() || "operation failed";
        this._toast(`Could not apply: ${msg}`);
      }
    }
  },
);

const app = new Adw.Application({ application_id: APP_ID, flags: Gio.ApplicationFlags.FLAGS_NONE });
app.connect("activate", () => {
  const win = app.get_active_window() ?? new SchedulerWindow(app);
  win.present();
});
app.run([system.programInvocationName, ...ARGV]);
