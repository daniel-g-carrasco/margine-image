# Margine live-environment image (Titanoboa / ADR-0008).
#
# Extends margine:stable into a bootable Live ISO payload that Titanoboa
# (ublue-os/titanoboa, pinned per ADR-0008 §3.1) turns into an ISO. The
# squashfs of the produced ISO IS this image's rootfs; the live boot
# launches a GNOME session (livesys) from which the user runs Anaconda
# to install margine:stable to disk.
#
# Built with:
#   podman build --cap-add sys_admin --security-opt label=disable \
#     --build-arg BASE_IMAGE=ghcr.io/daniel-g-carrasco/margine:stable \
#     -t margine-live:<tag> -f live-env/Containerfile live-env/
#
# The sys_admin cap + label=disable are required because build.sh
# regenerates the initramfs (dracut) and, from Phase 2 on, installs
# Flatpaks via bwrap which needs user namespaces.
#
# This image is NEVER published as a bootc :stable tag. It's built
# transiently in build-disk.yml with a run-scoped tag and fed to
# Titanoboa as image-ref. See ADR-0008 (margine-fedora-atomic).
ARG BASE_IMAGE=ghcr.io/daniel-g-carrasco/margine:stable

FROM ${BASE_IMAGE}

# build.sh + its data (iso.yaml, anaconda/, flatpaks) live under src/ and
# are bind-mounted at /src so they don't leak into the final image layers
# (and so live-env/references/ + README stay out of the build). rw because
# build.sh remounts /proc/sys and writes through /src during the bake.
# Build context is live-env/, so source=src resolves to live-env/src.
RUN --mount=type=bind,source=src,target=/src,rw \
    /src/build.sh
