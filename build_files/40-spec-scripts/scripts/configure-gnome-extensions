#!/usr/bin/env python3
"""
Enable GNOME Shell extensions declared in declarations/margine-atomic.yaml.

This is user-level state only. Extensions must already be installed by the host
layer (or otherwise present in GNOME's extension search path).

Usage:
    configure-gnome-extensions            # dry-run: print the plan
    configure-gnome-extensions --apply    # enable installed extensions
"""

from __future__ import annotations

import argparse
import ast
import os
import shutil
import subprocess
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.exit("python3 PyYAML is required")

REPO = Path(__file__).resolve().parent.parent
YAML = REPO / "declarations" / "margine-atomic.yaml"


def load_extensions() -> list[str]:
    if not YAML.is_file():
        sys.exit(f"declarations file not found: {YAML}")
    data = yaml.safe_load(YAML.read_text())
    try:
        return data["gnome"]["extensions"]["enable"]
    except (KeyError, TypeError):
        return []


def installed_on_disk() -> set[str]:
    """Extensions present on disk in user or system extension dirs.
    Note: gnome-extensions list ONLY returns what the current gnome-
    shell process has loaded, which doesn't reflect extensions that
    were just installed (need session restart). Disk check is the
    authoritative answer."""
    found = set()
    candidates = [
        os.path.expanduser("~/.local/share/gnome-shell/extensions"),
        "/usr/share/gnome-shell/extensions",
    ]
    for root in candidates:
        if not os.path.isdir(root):
            continue
        for entry in os.scandir(root):
            if entry.is_dir() and os.path.isfile(os.path.join(entry.path, "metadata.json")):
                found.add(entry.name)
    return found


def run(cmd: list[str], dry: bool) -> None:
    print("  $ " + " ".join(cmd))
    if dry:
        return
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        err = (result.stderr or result.stdout or "").strip().splitlines()
        first = err[0] if err else f"exit {result.returncode}"
        print(f"    (skipped: {first})")


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--apply",
        action="store_true",
        help="write changes via gnome-extensions (default: dry-run)",
    )
    args = parser.parse_args()
    dry = not args.apply

    if not dry and not shutil.which("gnome-extensions"):
        sys.exit("gnome-extensions not found in PATH")

    targets = load_extensions()
    on_disk = set() if dry else installed_on_disk()

    print("== GNOME Shell extensions ==")
    # Build the final list from the declaration. Anything on disk but
    # not currently loaded by the live shell would be refused by
    # `gnome-extensions enable` ("doesn't exist"), so we write the
    # canonical list directly to dconf. The next session restart will
    # then activate everything in the list that's on disk.
    final: list[str] = []
    for uuid in targets:
        if not dry and uuid not in on_disk:
            print(f"  ✗ NOT on disk: {uuid} — run install-user-extensions first")
            continue
        print(f"  + enable {uuid}")
        final.append(uuid)

    if not dry:
        # Anything currently enabled but absent from our declaration
        # gets dropped — the declaration is the source of truth, not
        # an additive overlay.
        try:
            current_raw = subprocess.check_output(
                ["gsettings", "get", "org.gnome.shell", "enabled-extensions"],
                text=True,
            ).strip()
            current_list = ast.literal_eval(current_raw)
            for uuid in current_list:
                if uuid not in final:
                    print(f"  - disable {uuid} (not declared)")
        except (subprocess.CalledProcessError, ValueError, SyntaxError) as e:
            print(f"  (could not read current enabled list: {e})")

        # Serialize as a GVariant array literal. Single quotes are the
        # gsettings expectation; no UUID will contain one.
        gvariant = "[" + ", ".join(f"'{u}'" for u in final) + "]"
        run(["gsettings", "set", "org.gnome.shell", "enabled-extensions", gvariant], dry)

    if dry:
        print("\ndry-run only: no settings were changed")
        print(f"apply with: {sys.argv[0]} --apply")
    else:
        print("\nApplied. Log out / log back in if GNOME Shell does not refresh immediately.")

    return 0


if __name__ == "__main__":
    sys.exit(main())
