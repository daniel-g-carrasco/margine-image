#!/usr/bin/env python3
"""
Install GNOME Shell extensions that are not in Fedora repos by downloading
them from extensions.gnome.org into ~/.local/share/gnome-shell/extensions/.

Reads gnome.extensions.user_install from declarations/margine-atomic.yaml
(list of {uuid, ego_id, description}).

Picks the right release for the running GNOME Shell version automatically
by querying https://extensions.gnome.org/extension-info/.

User-level only: never touches rpm-ostree, never asks for sudo. The
extension UUID directory is overwritten on re-install, so the script is
idempotent.

Usage:
    install-user-extensions             # dry-run: print the plan
    install-user-extensions --apply     # download and install
    install-user-extensions --remove    # remove the user-installed copies
"""

from __future__ import annotations

import argparse
import io
import json
import shutil
import subprocess
import sys
import tempfile
import urllib.request
import zipfile
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.exit("python3 PyYAML is required")

REPO = Path(__file__).resolve().parent.parent
YAML = REPO / "declarations" / "margine-atomic.yaml"
USER_EXT_DIR = Path.home() / ".local" / "share" / "gnome-shell" / "extensions"
EGO_INFO_URL = "https://extensions.gnome.org/extension-info/"
EGO_DOWNLOAD_URL = "https://extensions.gnome.org/download-extension/"


def gnome_shell_version() -> str:
    """Return the running GNOME Shell major version (e.g. '48')."""
    try:
        out = subprocess.run(
            ["gnome-shell", "--version"], capture_output=True, text=True, check=True
        ).stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return "48"  # sensible default for Margine target
    # "GNOME Shell 48.2" -> "48"
    parts = out.split()
    if len(parts) >= 3:
        return parts[2].split(".")[0]
    return "48"


def fetch_release_metadata(uuid: str, shell_version: str) -> dict:
    """Query the EGO API for the right release."""
    url = f"{EGO_INFO_URL}?uuid={uuid}&shell_version={shell_version}"
    with urllib.request.urlopen(url, timeout=30) as resp:
        return json.loads(resp.read())


def download_zip(uuid: str, version_tag: int) -> bytes:
    url = (
        f"{EGO_DOWNLOAD_URL}{uuid}.shell-extension.zip"
        f"?version_tag={version_tag}"
    )
    with urllib.request.urlopen(url, timeout=60) as resp:
        return resp.read()


def install_from_ego(uuid: str, ego_id: int, dry: bool, shell_version: str) -> None:
    print(f"\n== {uuid} (ego_id={ego_id}, source=extensions.gnome.org) ==")
    try:
        meta = fetch_release_metadata(uuid, shell_version)
    except Exception as exc:
        print(f"  (skip: cannot fetch EGO metadata: {exc})")
        return

    version_tag = meta.get("version_tag")
    version = meta.get("version")
    if not version_tag:
        print(f"  (skip: no release for GNOME {shell_version})")
        return

    print(f"  GNOME Shell version: {shell_version}")
    print(f"  Release: v{version}  (version_tag={version_tag})")
    target_dir = USER_EXT_DIR / uuid
    print(f"  Target: {target_dir}")

    if dry:
        return

    try:
        blob = download_zip(uuid, version_tag)
    except Exception as exc:
        print(f"  (skip: download failed: {exc})")
        return

    USER_EXT_DIR.mkdir(parents=True, exist_ok=True)
    if target_dir.exists():
        shutil.rmtree(target_dir)
    target_dir.mkdir(parents=True)

    with zipfile.ZipFile(io.BytesIO(blob)) as zf:
        zf.extractall(target_dir)

    print(f"  Installed: {target_dir}")


def install_from_git(uuid: str, git_url: str, git_ref: str | None, dry: bool) -> None:
    print(f"\n== {uuid} (source=git: {git_url}@{git_ref or 'HEAD'}) ==")
    target_dir = USER_EXT_DIR / uuid
    print(f"  Target: {target_dir}")
    if dry:
        return

    USER_EXT_DIR.mkdir(parents=True, exist_ok=True)
    if target_dir.exists():
        shutil.rmtree(target_dir)

    with tempfile.TemporaryDirectory() as tmpd:
        clone_dir = Path(tmpd) / "ext"
        cmd = ["git", "clone", "--depth=1"]
        if git_ref:
            cmd.extend(["--branch", git_ref])
        cmd.extend([git_url, str(clone_dir)])
        subprocess.run(cmd, check=True, capture_output=True, text=True)

        # The extension content can be either at the repo root (most
        # extensions) or in a subdir. Detect by looking for metadata.json.
        meta_path = clone_dir / "metadata.json"
        if not meta_path.is_file():
            # Try src/ or extension/ subdir conventions
            for sub in ("src", "extension"):
                if (clone_dir / sub / "metadata.json").is_file():
                    clone_dir = clone_dir / sub
                    break
        if not (clone_dir / "metadata.json").is_file():
            print(f"  (skip: metadata.json not found in clone)")
            return

        # Some extensions need a build step. We don't run it here; we trust
        # the repo to be self-contained (most search-light style extensions
        # are pure JS + schemas). If a build is needed, vendor a built
        # release instead.
        shutil.copytree(clone_dir, target_dir, symlinks=True)
        # Drop .git to keep the dir clean
        gitdir = target_dir / ".git"
        if gitdir.is_dir():
            shutil.rmtree(gitdir)

    print(f"  Installed: {target_dir}")


def install_one(uuid: str, entry: dict, dry: bool, shell_version: str) -> None:
    # entry may have 'ego_id' OR 'git_url' (+optional 'git_ref').
    target_dir = USER_EXT_DIR / uuid
    git_url = entry.get("git_url")
    if git_url:
        install_from_git(uuid, git_url, entry.get("git_ref"), dry)
    elif entry.get("ego_id"):
        install_from_ego(uuid, entry["ego_id"], dry, shell_version)
    else:
        print(f"\n== {uuid} ==")
        print("  (skip: entry has neither ego_id nor git_url)")
        return

    if dry:
        return

    # Compile schemas in the extension dir (required for the extension itself)
    ext_schemas = target_dir / "schemas"
    if ext_schemas.is_dir() and any(ext_schemas.glob("*.xml")):
        subprocess.run(
            ["glib-compile-schemas", str(ext_schemas)],
            check=False,
        )
        # Also copy schemas to ~/.local/share/glib-2.0/schemas/ so the
        # `gsettings` CLI (and our configure-gnome-* scripts) can find
        # them without the GSETTINGS_SCHEMA_DIR env var. GNOME Shell
        # itself reads the extension dir directly, but the CLI doesn't.
        user_glib_schemas = Path.home() / ".local" / "share" / "glib-2.0" / "schemas"
        user_glib_schemas.mkdir(parents=True, exist_ok=True)
        for xml in ext_schemas.glob("*.xml"):
            shutil.copy(xml, user_glib_schemas / xml.name)
        subprocess.run(
            ["glib-compile-schemas", str(user_glib_schemas)],
            check=False,
        )
        print(f"  Schemas: compiled in ext dir + copied/compiled in {user_glib_schemas}")

    print(
        "  Enable next with:  scripts/configure-gnome-extensions --apply"
        f"  (or: gnome-extensions enable {uuid})"
    )


def remove_one(uuid: str, dry: bool) -> None:
    target_dir = USER_EXT_DIR / uuid
    print(f"\n== {uuid} ==")
    if not target_dir.exists():
        print(f"  (not present at {target_dir})")
        return
    print(f"  $ rm -rf {target_dir}")
    if not dry:
        shutil.rmtree(target_dir)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--apply", action="store_true", help="actually download/extract")
    parser.add_argument(
        "--remove",
        action="store_true",
        help="remove user-installed copies instead of installing",
    )
    args = parser.parse_args()
    dry = not args.apply

    if not YAML.is_file():
        sys.exit(f"declarations file not found: {YAML}")
    data = yaml.safe_load(YAML.read_text())
    try:
        entries = data["gnome"]["extensions"]["user_install"] or []
    except (KeyError, TypeError):
        entries = []
    if not entries:
        print("No user_install extensions declared. Nothing to do.")
        return 0

    shell_version = gnome_shell_version()
    print(f"Detected GNOME Shell version: {shell_version}")
    print(f"User extension dir: {USER_EXT_DIR}")

    for entry in entries:
        uuid = entry["uuid"]
        if args.remove:
            remove_one(uuid, dry)
        else:
            install_one(uuid, entry, dry, shell_version)

    if dry:
        print(f"\ndry-run only. Apply with: {sys.argv[0]} --apply")
    else:
        print("\nDone. Log out / log back in for GNOME to pick up new extensions.")
        print("Then enable them:  scripts/configure-gnome-extensions --apply")

    return 0


if __name__ == "__main__":
    sys.exit(main())
