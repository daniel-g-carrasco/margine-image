#!/usr/bin/env python3
"""On first graphical login after a reboot, if the booted deployment's
image digest differs from the one recorded at last run, raise a
notification telling the user *which version they just upgraded to*.
Reassures them that the reboot actually did something.

2026-07-10 rewrite, after "I never saw any of this" (daniel):
 - bootc omits .status.booted.image on client-layered deployments
   (e.g. after ujust margine-gaming-native), which made this crash;
   fall back to rpm-ostree and select the deployment with booted=true
   (deployments[0] is the STAGED one when an update is pending).
 - the state file was written even when the notification failed or the
   toast was lost, so a missed notification never retried; now state
   advances only after the notification succeeds.
 - state moved from ~/.cache (routinely wiped) to XDG_STATE_HOME.
 - the unit moved from default.target.wants to
   graphical-session.target.wants: default.target starts before the
   session's notification daemon is up, so the toast fired into the
   void."""

import json
import os
import pathlib
import subprocess
import sys


def read_json(cmd):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        if r.returncode != 0:
            return {}
        return json.loads(r.stdout)
    except Exception:
        return {}


digest = ""
version = ""

st = read_json(["bootc", "status", "--json"])
image = ((st.get("status") or {}).get("booted") or {}).get("image") or {}
digest = image.get("imageDigest") or ""
version = image.get("version") or ""

if not digest:
    ros = read_json(["rpm-ostree", "status", "--json"])
    booted = next(
        (d for d in ros.get("deployments", []) if d.get("booted")), {}
    )
    digest = (booted.get("base-commit-meta") or {}).get(
        "ostree.manifest-digest"
    ) or ""
    version = version or booted.get("version") or "?"

if not digest:
    sys.exit(0)

state_dir = pathlib.Path(
    os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state"))
) / "margine"
state_dir.mkdir(parents=True, exist_ok=True)
state_file = state_dir / "last-booted-digest"
# One-time migration from the old ~/.cache location, so existing
# installs don't re-announce their current deployment as "new".
legacy = pathlib.Path(os.path.expanduser("~/.cache/margine/last-booted-digest"))
if not state_file.exists() and legacy.exists():
    state_file.write_text(legacy.read_text())

previous = state_file.read_text().strip() if state_file.exists() else ""

if previous and previous != digest:
    title = "Margine updated"
    body = f"Now running: {version}\nDigest: {digest[:23]}…"
    # margine-notify, not notify-send: it fills the fdo app_icon field
    # so the logo also shows on the lock screen (docs/BRANDING.md).
    r = subprocess.run(
        ["/usr/libexec/margine/margine-notify", "-u", "normal", title, body]
    )
    if r.returncode != 0:
        # No notification daemon yet: keep the old state so the next
        # login retries instead of silently losing the announcement.
        sys.exit(0)

state_file.write_text(digest)
