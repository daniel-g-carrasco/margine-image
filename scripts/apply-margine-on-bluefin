#!/usr/bin/env bash
#
# Apply the Margine delta on top of a Bluefin DX deployment.
#
# Assumes the system has already been rebased to:
#   ostree-unverified-registry:ghcr.io/ublue-os/bluefin-dx:stable
#
# The delta is the 5 differences documented in
# docs/adr/0005-base-on-bluefin-dx.md:
#
#   1. Layer kernel-cachyos from the bieszczaders/kernel-cachyos COPR,
#      replacing Bluefin's signed kernel.
#   2. Layer kitty.
#   3. Disable Bluefin's branding extensions (bazaar-integration,
#      gradia-integration, logomenu). The packages stay installed.
#   4. Install Tiling Shell user-level (via install-user-extensions).
#   5. Apply Margine user state via the existing configure-gnome-* and
#      configure-default-applications scripts.
#
# Re-runnable. Each step checks current state and skips when applicable.
#
# Usage:
#   apply-margine-on-bluefin               # dry-run: print the plan
#   apply-margine-on-bluefin --apply       # execute
#   apply-margine-on-bluefin --apply --skip-kernel   # skip the kernel layer
#
set -euo pipefail

apply=0
skip_kernel=0

usage() {
  cat <<EOF
Usage: $0 [--apply] [--skip-kernel]

  --apply         Execute (default: dry-run)
  --skip-kernel   Don't touch the kernel layer (useful when iterating
                  on the desktop-side changes without paying a reboot)
EOF
}

while (($#)); do
  case "$1" in
    --apply) apply=1 ; shift ;;
    --skip-kernel) skip_kernel=1 ; shift ;;
    -h|--help) usage ; exit 0 ;;
    *) echo "Unknown argument: $1" >&2 ; usage >&2 ; exit 2 ;;
  esac
done

repo_root="$(cd "$(dirname "$0")/.." && pwd)"

section() { printf '\n== %s ==\n' "$1" ; }

run() {
  printf '  $ %s\n' "$*"
  if (( apply )); then
    "$@"
  fi
}

# --- preflight: confirm we are on a Bluefin DX deployment ---------------
section "Preflight"
if command -v rpm-ostree >/dev/null 2>&1; then
  origin_url="$(rpm-ostree status --json 2>/dev/null \
    | python3 -c 'import json,sys; d=json.load(sys.stdin); print((d["deployments"] or [{}])[0].get("origin","") or "")')"
  printf '  Current deployment origin: %s\n' "$origin_url"
  if [[ "$origin_url" != *bluefin-dx* ]]; then
    echo "  WARNING: current deployment does not look like Bluefin DX."
    echo "  Expected origin to contain 'bluefin-dx'."
    echo "  Continue at your own risk; this script assumes Bluefin DX as base."
  fi
else
  echo "  rpm-ostree not found (host is not Fedora Atomic?). Continuing dry-run."
fi

# --- step 1: kernel-cachyos layer ----------------------------------------
section "Step 1 — Layer kernel-cachyos (Margine kernel choice)"
if (( skip_kernel )); then
  echo "  --skip-kernel set; skipping."
else
  releasever_default=44
  if command -v rpm >/dev/null 2>&1; then
    releasever_default="$(rpm -E %fedora)"
  fi
  copr_repo_url="https://copr.fedorainfracloud.org/coprs/bieszczaders/kernel-cachyos/repo/fedora-${releasever_default}/bieszczaders-kernel-cachyos-fedora-${releasever_default}.repo"
  copr_repo_path="/etc/yum.repos.d/bieszczaders-kernel-cachyos-fedora-${releasever_default}.repo"

  if [[ -f "$copr_repo_path" ]]; then
    echo "  CachyOS COPR repo already enabled — skip."
  else
    run sudo curl --fail --location --silent --show-error \
        --output "$copr_repo_path" "$copr_repo_url"
  fi

  cachyos_already_layered=0
  if command -v rpm-ostree >/dev/null 2>&1; then
    if rpm-ostree status --json 2>/dev/null \
      | python3 -c '
import json, sys
data = json.loads(sys.stdin.read() or "{}")
for d in data.get("deployments", [])[:2]:
    requested = (d.get("requested-packages") or []) + (d.get("packages") or [])
    if any("kernel-cachyos" in str(p) for p in requested):
        sys.exit(0)
sys.exit(1)
'; then
      cachyos_already_layered=1
    fi
  fi

  if (( cachyos_already_layered )); then
    echo "  kernel-cachyos already layered — skip."
  else
    run sudo rpm-ostree override remove \
        kernel kernel-core kernel-modules kernel-modules-core kernel-modules-extra \
        --install kernel-cachyos
  fi
fi

# --- step 2: kitty as terminal -------------------------------------------
section "Step 2 — Layer kitty"
kitty_installed=0
if command -v rpm-ostree >/dev/null 2>&1; then
  if rpm-ostree status --json 2>/dev/null \
    | python3 -c '
import json, sys
data = json.loads(sys.stdin.read() or "{}")
for d in data.get("deployments", [])[:2]:
    requested = (d.get("requested-packages") or []) + (d.get("packages") or [])
    if "kitty" in (str(p) for p in requested):
        sys.exit(0)
sys.exit(1)
'; then
    kitty_installed=1
  fi
fi

if (( kitty_installed )); then
  echo "  kitty already layered — skip rpm-ostree install."
else
  run sudo rpm-ostree install kitty
fi

# Default terminal: handled by configure-gnome-appearance writing
# gnome.default_applications.terminal_emulator, applied by
# configure-default-applications. Nothing to do here beyond making sure
# kitty is on disk.

# --- step 3: disable Bluefin branding extensions ------------------------
section "Step 3 — Disable Bluefin branding extensions"
branding_extensions=(
  "bazaar-integration@kolunmi.github.io"
  "gradia-integration@alexandervanhee.github.io"
  "logomenu@aryan_k"
)
if command -v gnome-extensions >/dev/null 2>&1; then
  for uuid in "${branding_extensions[@]}"; do
    if gnome-extensions list --enabled 2>/dev/null | grep -qx "$uuid"; then
      run gnome-extensions disable "$uuid"
    else
      echo "  (not enabled: $uuid)"
    fi
  done
else
  echo "  (gnome-extensions not available; would disable: ${branding_extensions[*]})"
fi

# --- step 4: install Tiling Shell user-level ----------------------------
section "Step 4 — Install Tiling Shell user-level"
if [[ -x "${repo_root}/scripts/install-user-extensions" ]]; then
  if (( apply )); then
    "${repo_root}/scripts/install-user-extensions" --apply
  else
    "${repo_root}/scripts/install-user-extensions"
  fi
else
  echo "  (install-user-extensions missing; skipping)"
fi

# --- step 5: apply Margine user state -----------------------------------
section "Step 5 — Apply Margine user state (extensions/keybindings/appearance/apps/folders)"
for s in configure-gnome-extensions configure-gnome-keybindings \
         configure-gnome-appearance configure-default-applications \
         configure-gnome-app-folders; do
  script_path="${repo_root}/scripts/${s}"
  if [[ -x "$script_path" ]]; then
    if (( apply )); then
      "$script_path" --apply
    else
      "$script_path"
    fi
  else
    echo "  (${s} missing; skipping)"
  fi
done

# --- done ----------------------------------------------------------------
if (( apply )); then
  section "Done"
  cat <<EOF
The Margine delta has been applied on top of Bluefin DX.

If kernel-cachyos was newly layered (step 1), a new rpm-ostree deployment
is staged. Reboot from the GNOME menu (Power → Restart) to enter it.

For desktop-side changes (steps 3, 4, 5) a logout / log back in is
enough on Wayland to fully refresh GNOME Shell.
EOF
else
  section "Dry-run complete"
  echo "Apply with: $0 --apply"
fi
