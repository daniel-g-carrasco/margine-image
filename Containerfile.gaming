# =============================================================================
# Margine Gaming variant — Margine + gaming host RPMs + gaming Flatpaks
# =============================================================================
#
# This Containerfile composes the Margine Gaming image as:
#
#   FROM ghcr.io/danielgrasso/margine:stable   (already-validated base)
#   + gamescope / mangohud / vkBasalt / gamemode / goverlay / etc. RPMs
#   + steam-devices (udev rules) + input-remapper + tuned + rom-properties
#   + Flatpak preinstall list (Steam, Lutris, Heroic, Bottles, …)
#
# Built by GitHub Actions on workflow_dispatch and after every successful
# smoke-boot of the base image (workflow_run trigger). Pushed to:
#   ghcr.io/danielgrasso/margine-gaming:stable
#
# Why a separate image instead of `ujust margine-gaming` (rpm-ostree layered)?
# See ~/.claude/.../memory/project_todo_margine_gaming_image_variant.md.
# tl;dr: the layered approach branches every user's deployment from the
# pristine base, so `rpm-ostree status` shows LayeredPackages and every
# `bootc upgrade` re-applies the layer (slow, occasional conflicts).
# This image variant gives a 100% ostree-canonical deployment, signed
# by digest, fast upgrade, with the same gaming stack baked in.
#
# End-user install:
#   bootc switch ghcr.io/danielgrasso/margine-gaming:stable
# (one-time migration from the base image to the gaming variant).
# =============================================================================

ARG BASE_IMAGE=ghcr.io/danielgrasso/margine:stable

# ----- Build context: scripts that should NOT end up in the final image -----
FROM scratch AS ctx
COPY build_files /
# Same single-source-of-truth setup as the base Containerfile:
# expose installer/flatpaks-{base,gaming} as plain files in /ctx/
# so build_files/gaming/install.sh can `cp` them into
# /usr/share/margine/. Audit §3.5.
COPY installer/flatpaks-base    /installer-flatpaks-base
COPY installer/flatpaks-gaming  /installer-flatpaks-gaming

# ----- Base: Margine (which already has CachyOS kernel + branding + ujust)
# Kernel is already MOK-signed in the base; we do NOT touch it here, so this
# layer does not need the MOK secrets at all — pure dnf install + skel drop. -----
FROM ${BASE_IMAGE}

# ----- Gaming RPM stack -----
# Same set as `ujust margine-gaming`, but baked at image-build time so the
# resulting deployment is ostree-canonical. Notes:
#  - gamescope / mangohud / vkBasalt / gamemode / goverlay are Vulkan
#    layers + GUI configurators that integrate with Wayland and the
#    GPU driver stack at the host level — cannot be Flatpak'd.
#  - steam-devices ships the controller udev rules.
#  - input-remapper provides the GUI + daemon for remapping gamepad /
#    keyboard / mouse without per-device drivers.
#  - tuned + tuned-ppd: profile-based CPU governor switching (the -ppd
#    shim makes GNOME's power-profiles UI control tuned profiles).
#  - rom-properties-gtk: Nautilus column extension for ROM metadata.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/gaming/install.sh

# ----- Flatpak preinstall list (gaming clients) -----
# Triggers on first user login via flatpak-preinstall.service. Same
# 7 apps that `ujust margine-gaming` would install, declared once
# in /usr/share/flatpak/preinstall.d/.
COPY build_files/gaming/margine-gaming.preinstall \
     /usr/share/flatpak/preinstall.d/margine-gaming.preinstall

# ----- Identity: distinguish this variant from the base in os-release ----
# Sets VARIANT_ID=gaming so `lsb_release -i` and `bootc status` make
# the variant obvious; PRETTY_NAME gets the "Gaming" suffix; LOGO stays
# the same (margine-logo). VERSION_ID inherited from base.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    /ctx/gaming/stamp-os-release.sh

# ----- Lint: verify final image is a valid bootc container -----
RUN bootc container lint
