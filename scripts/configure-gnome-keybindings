#!/usr/bin/env python3
"""
Configure GNOME keybindings from gnome.keybindings in
declarations/margine-atomic.yaml.

Applies five groups, each via its own gsettings schema:

  workspace   -> org.gnome.desktop.wm.keybindings
  window      -> org.gnome.desktop.wm.keybindings
  shell       -> org.gnome.shell.keybindings
  media_keys  -> org.gnome.settings-daemon.plugins.media-keys
  forge       -> org.gnome.shell.extensions.forge.keybindings
  custom      -> custom-keybindings (relocatable schema slots)

Also sets the GNOME workspace model from gnome.workspaces.

Usage:
    configure-gnome-keybindings            # dry-run: print the plan
    configure-gnome-keybindings --apply    # write via gsettings
    configure-gnome-keybindings --reset    # remove custom slots
"""

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.exit("python3 PyYAML is required")

REPO = Path(__file__).resolve().parent.parent
YAML = REPO / "declarations" / "margine-atomic.yaml"

WM_KEYS = {
    "switch_next": "switch-to-workspace-right",
    "switch_previous": "switch-to-workspace-left",
    "switch_last_used": "switch-to-workspace-last",
    "switch_to_1": "switch-to-workspace-1",
    "switch_to_2": "switch-to-workspace-2",
    "switch_to_3": "switch-to-workspace-3",
    "switch_to_4": "switch-to-workspace-4",
    "switch_to_5": "switch-to-workspace-5",
    "switch_to_6": "switch-to-workspace-6",
    "switch_to_7": "switch-to-workspace-7",
    "switch_to_8": "switch-to-workspace-8",
    "switch_to_9": "switch-to-workspace-9",
    "switch_to_10": "switch-to-workspace-10",
    "move_window_to_1": "move-to-workspace-1",
    "move_window_to_2": "move-to-workspace-2",
    "move_window_to_3": "move-to-workspace-3",
    "move_window_to_4": "move-to-workspace-4",
    "move_window_to_5": "move-to-workspace-5",
    "move_window_to_6": "move-to-workspace-6",
    "move_window_to_7": "move-to-workspace-7",
    "move_window_to_8": "move-to-workspace-8",
    "move_window_to_9": "move-to-workspace-9",
    "move_window_to_10": "move-to-workspace-10",
    "close": "close",
    "toggle_fullscreen": "toggle-fullscreen",
    "always_on_top": "always-on-top",
}

SHELL_KEYS = {
    "toggle_application_view": "toggle-application-view",
    "toggle_overview": "toggle-overview",
    "toggle_message_tray": "toggle-message-tray",  # GNOME 48 name
    "show_screenshot_ui": "show-screenshot-ui",
    "screenshot_window": "screenshot-window",
    "show_screen_recording_ui": "show-screen-recording-ui",
}

# Keys whose GNOME defaults collide with Margine's keybindings spec.
# Audited 2026-05-31 on a booted Margine system — see lessons-learned
# Bug 12. Resetting each to empty `@as []` so our intended binding (set
# elsewhere in this script) is the sole owner of the chord.

SHELL_KEYS_TO_CLEAR = (
    # switch-to-application-N defaults to <Super>1..9. We use those
    # for switch-to-workspace-N instead.
    "switch-to-application-1",
    "switch-to-application-2",
    "switch-to-application-3",
    "switch-to-application-4",
    "switch-to-application-5",
    "switch-to-application-6",
    "switch-to-application-7",
    "switch-to-application-8",
    "switch-to-application-9",
    # focus-active-notification defaults to <Super>n; we use that for
    # toggle-message-tray.
    "focus-active-notification",
)

# WM keybindings whose defaults shadow our intent.
WM_KEYS_TO_CLEAR = (
    # switch-applications + backward default to <Super>Tab / <Shift>+<Super>Tab,
    # which we redirect to switch-to-workspace-right / left.
    "switch-applications",
    "switch-applications-backward",
    # move-to-monitor-* default to <Super><Shift>arrow, which we use for
    # Tiling Shell move-window-*. Without clearing these the chord is
    # captured by mutter to move-to-monitor instead of the extension.
    "move-to-monitor-up",
    "move-to-monitor-down",
    "move-to-monitor-left",
    "move-to-monitor-right",
)

# media-keys defaults that clobber our custom shortcuts.
MEDIA_KEYS_TO_CLEAR = (
    # home defaults to <Super>e; we use that for our custom
    # `file_manager` keybinding (nautilus).
    "home",
    # rotate-video-lock-static defaults to <Super>o; we use that for
    # wm.always-on-top.
    "rotate-video-lock-static",
)

# Extension settings that grab keys we want Margine to own.
# Each entry is (dconf-path, value). We write via `dconf write` rather
# than `gsettings set` because the gschema may not be loaded into the
# current gnome-shell process when this script runs (e.g. extension
# enabled but session not restarted yet). dconf write bypasses the
# schema check; the extension picks it up next time it reads dconf.
EXTENSION_OVERRIDES = (
    # dash-to-dock's hot-keys=true binds <Super>1..9,0 to launch the
    # N-th pinned app. We bind those to switch-to-workspace-N. Disable
    # dash-to-dock's hot-keys flag so the shortcut goes to the WM
    # binding instead. Pin behavior in the dock itself (click to
    # launch) is unchanged.
    ("/org/gnome/shell/extensions/dash-to-dock/hot-keys", "false"),
)

MEDIA_KEYS = {
    "screensaver": "screensaver",
}

CUSTOM_BASE_PATH = "/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/"
CUSTOM_LIST_SCHEMA = "org.gnome.settings-daemon.plugins.media-keys"


def gvariant_strings(items: list[str]) -> str:
    quoted = ", ".join(f"'{x}'" for x in items)
    return f"[{quoted}]"


def gvariant_string(item: str) -> str:
    escaped = item.replace("\\", "\\\\").replace("'", "\\'")
    return f"'{escaped}'"


def run(cmd: list[str], dry: bool) -> None:
    print("  $ " + " ".join(cmd))
    if not dry:
        subprocess.run(cmd, check=True)


def run_soft(cmd: list[str], dry: bool) -> None:
    """Run a gsettings command but don't abort the script on failure.

    Missing schemas (e.g. Forge before the extension is enabled) and
    missing keys (e.g. a GNOME version where a shortcut was renamed)
    are logged as 'skipped' rather than crashing the whole apply.
    """
    print("  $ " + " ".join(cmd))
    if dry:
        return
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        err = (result.stderr or "").strip().splitlines()
        first = err[0] if err else f"exit {result.returncode}"
        print(f"    (skipped: {first})")


def set_key(schema: str, key: str, value, dry: bool) -> None:
    if isinstance(value, list):
        gv = gvariant_strings(value)
    elif isinstance(value, str):
        gv = gvariant_strings([value])
    else:
        gv = str(value)
    run_soft(["gsettings", "set", schema, key, gv], dry)


def set_string_key(schema: str, key: str, value: str, dry: bool) -> None:
    run_soft(["gsettings", "set", schema, key, gvariant_string(value)], dry)


def apply_workspaces(ws: dict, dry: bool) -> None:
    dynamic = bool(ws.get("dynamic", False))
    model = "dynamic" if dynamic else "static"
    print(f"\n== Workspaces ({model} model) ==")
    run(
        [
            "gsettings",
            "set",
            "org.gnome.mutter",
            "dynamic-workspaces",
            "true" if dynamic else "false",
        ],
        dry,
    )
    if dynamic:
        print("  (dynamic mode: GNOME creates/removes workspaces as needed)")
    else:
        run(
            [
                "gsettings",
                "set",
                "org.gnome.desktop.wm.preferences",
                "num-workspaces",
                str(ws.get("count", 4)),
            ],
            dry,
        )
    names = ws.get("names", [])
    if names:
        run(
            [
                "gsettings",
                "set",
                "org.gnome.desktop.wm.preferences",
                "workspace-names",
                gvariant_strings(names),
            ],
            dry,
        )


def apply_group(
    title: str, schema: str, mapping: dict[str, str], group_yaml: dict, dry: bool
) -> None:
    print(f"\n== {title}  ->  {schema} ==")
    for yaml_key, value in group_yaml.items():
        gset_key = mapping.get(yaml_key)
        if gset_key is None:
            print(f"  (skip unmapped key: {yaml_key})")
            continue
        set_key(schema, gset_key, value, dry)


def apply_tilingshell(ts_yaml: dict, dry: bool) -> None:
    schema = "org.gnome.shell.extensions.tilingshell"
    print(f"\n== Tiling Shell  ->  {schema} ==")
    print("  (Tiling Shell schema is loaded only after the extension is enabled;")
    print("   if gsettings complains about an unknown schema, run:")
    print("     scripts/install-user-extensions --apply")
    print("     gnome-extensions enable tilingshell@ferrarodomenico.com")
    print("   then re-run this script.)")
    for yaml_key, value in ts_yaml.items():
        # YAML keys are already in dash-case for tilingshell
        gset_key = yaml_key
        set_key(schema, gset_key, value, dry)


def apply_custom(custom_list: list[dict], dry: bool) -> None:
    print("\n== Custom keybindings (app launchers) ==")
    paths = [f"{CUSTOM_BASE_PATH}{c['name']}/" for c in custom_list]
    run(
        [
            "gsettings",
            "set",
            CUSTOM_LIST_SCHEMA,
            "custom-keybindings",
            gvariant_strings(paths),
        ],
        dry,
    )
    for c in custom_list:
        path = f"{CUSTOM_BASE_PATH}{c['name']}/"
        schema = f"org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:{path}"
        print(f"  -- {c['name']}  ->  {c['binding']}  ->  {c['command']}")
        set_string_key(schema, "name", c["name"], dry)
        set_string_key(schema, "command", c["command"], dry)
        set_string_key(schema, "binding", c["binding"], dry)


def reset_custom(custom_list: list[dict], dry: bool) -> None:
    print("\n== Reset custom keybindings ==")
    run(["gsettings", "set", CUSTOM_LIST_SCHEMA, "custom-keybindings", "[]"], dry)
    for c in custom_list:
        path = f"{CUSTOM_BASE_PATH}{c['name']}/"
        run(["dconf", "reset", "-f", path], dry)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--apply",
        action="store_true",
        help="write changes via gsettings (default: dry-run)",
    )
    parser.add_argument(
        "--reset",
        action="store_true",
        help="reset custom keybindings (does not touch native shortcuts)",
    )
    args = parser.parse_args()

    if not YAML.is_file():
        sys.exit(f"declarations file not found: {YAML}")
    data = yaml.safe_load(YAML.read_text())
    try:
        ws = data["gnome"]["workspaces"]
        kb = data["gnome"]["keybindings"]
    except (KeyError, TypeError):
        sys.exit("gnome.workspaces or gnome.keybindings missing from declarations")

    dry = not args.apply

    if not dry:
        for tool in ("gsettings", "dconf"):
            if not shutil.which(tool):
                sys.exit(f"{tool} not found in PATH")

    if args.reset:
        reset_custom(kb.get("custom", []), dry)
    else:
        apply_workspaces(ws, dry)
        workspace_bindings = kb.get("workspace", {})
        apply_group(
            "Workspace + window (WM keybindings)",
            "org.gnome.desktop.wm.keybindings",
            WM_KEYS,
            {**workspace_bindings, **kb.get("window", {})},
            dry,
        )
        print("\n== Clear conflicting GNOME defaults ==")
        print("   (so the chord reaches the Margine binding instead)")
        for key in WM_KEYS_TO_CLEAR:
            set_key("org.gnome.desktop.wm.keybindings", key, [], dry)
        for key in SHELL_KEYS_TO_CLEAR:
            set_key("org.gnome.shell.keybindings", key, [], dry)
        for key in MEDIA_KEYS_TO_CLEAR:
            set_key("org.gnome.settings-daemon.plugins.media-keys", key, [], dry)
        for path, val in EXTENSION_OVERRIDES:
            print(f"  dconf write {path} {val}")
            run_soft(["dconf", "write", path, val], dry)

        apply_group(
            "Shell",
            "org.gnome.shell.keybindings",
            SHELL_KEYS,
            kb.get("shell", {}),
            dry,
        )
        apply_group(
            "Media keys",
            "org.gnome.settings-daemon.plugins.media-keys",
            MEDIA_KEYS,
            kb.get("media_keys", {}),
            dry,
        )
        apply_custom(kb.get("custom", []), dry)
        apply_tilingshell(kb.get("tilingshell", {}), dry)

    if dry:
        print("\ndry-run only: no settings were changed")
        print(f"apply with: {sys.argv[0]} --apply")
    else:
        print("\nApplied. Log out / log back in for some shortcuts to take effect.")

    return 0


if __name__ == "__main__":
    sys.exit(main())
