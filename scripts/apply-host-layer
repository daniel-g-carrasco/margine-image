#!/usr/bin/env bash
#
# Apply the Margine host layer baseline:
#   - Enable RPMFusion (free + nonfree)
#   - Replace ffmpeg-free / mesa-va-drivers / mesa-vdpau-drivers with
#     the freeworld variants from RPMFusion (full codec coverage)
#   - Install the baseline package set (codec, mesa, virt, hw diag,
#     gnome-tweaks, curated fonts) from host_packages.baseline in
#     declarations/margine-atomic.yaml
#
# This is a destructive operation on the rpm-ostree deployment:
# it creates a new staged deployment and requires a reboot.
#
# Default mode is dry-run. Use --apply to stage the deployment.
#
# Usage:
#   apply-host-layer                # dry-run, prints the plan
#   apply-host-layer --apply        # stage the new deployment
#   apply-host-layer --apply --reboot   # stage and reboot via GNOME
#
set -euo pipefail

apply=0
reboot_after=0

usage() {
  cat <<EOF
Usage: $0 [--apply] [--reboot]

  --apply    Run rpm-ostree commands (default: dry-run)
  --reboot   After --apply, suggest the GNOME reboot path
EOF
}

while (($#)); do
  case "$1" in
    --apply) apply=1 ; shift ;;
    --reboot) reboot_after=1 ; shift ;;
    -h|--help) usage ; exit 0 ;;
    *) echo "Unknown argument: $1" >&2 ; usage >&2 ; exit 2 ;;
  esac
done

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
yaml="${repo_root}/declarations/margine-atomic.yaml"

if [[ ! -r "$yaml" ]]; then
  echo "Declarations file not readable: $yaml" >&2
  exit 1
fi

# Pull baseline package lists out of the YAML.
read_list() {
  local key="$1"
  python3 - "$yaml" "$key" <<'PY'
import sys, yaml
data = yaml.safe_load(open(sys.argv[1]).read())
key = sys.argv[2]
node = data
for p in key.split('.'):
    node = node[p]
if isinstance(node, dict):
    for v in node.values():
        if isinstance(v, list):
            for item in v:
                print(item)
else:
    for item in node:
        print(item)
PY
}

mapfile -t OVERRIDE_REMOVE < <(read_list "host_packages.baseline.codec_replacement.override_remove")
mapfile -t CODEC_INSTALL   < <(read_list "host_packages.baseline.codec_replacement.install")
mapfile -t MEDIA_DIAG      < <(read_list "host_packages.baseline.media_diagnostics")
mapfile -t AUDIO           < <(read_list "host_packages.baseline.audio_baseline")
mapfile -t VIRT            < <(read_list "host_packages.baseline.virtualization")
mapfile -t HW_DIAG         < <(read_list "host_packages.baseline.hardware_diagnostics")
mapfile -t GNOME_TOOLS     < <(read_list "host_packages.baseline.gnome_tools")
mapfile -t FONTS           < <(read_list "host_packages.baseline.fonts")
mapfile -t CREATIVE_APPS   < <(read_list "host_packages.baseline.creative_apps")

if command -v rpm >/dev/null 2>&1; then
  FEDORA_VER="$(rpm -E %fedora)"
else
  FEDORA_VER="${FEDORA_VER:-44}"
  if (( apply )); then
    echo "rpm not found; refusing to --apply outside Fedora." >&2
    exit 1
  fi
  echo "Note: rpm not found (not on Fedora). Showing dry-run with assumed FEDORA_VER=${FEDORA_VER}." >&2
fi
RPMFUSION_FREE="https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VER}.noarch.rpm"
RPMFUSION_NONFREE="https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VER}.noarch.rpm"

run() {
  printf '  $ %s\n' "$*"
  if (( apply )); then
    "$@"
  fi
}

section() { printf '\n== %s ==\n' "$1" ; }

section "Step 1 — Enable RPMFusion (free + nonfree)"
rpmfusion_already_layered() {
  # Returns 0 if both rpmfusion-{free,nonfree}-release are already layered
  # in the staged or booted deployment, 1 otherwise.
  command -v rpm-ostree >/dev/null 2>&1 || return 1
  local status_json
  status_json="$(rpm-ostree status --json 2>/dev/null)" || return 1
  printf '%s' "$status_json" | python3 -c '
import json, sys
try:
    data = json.loads(sys.stdin.read())
except Exception:
    sys.exit(1)
needles = ("rpmfusion-free-release", "rpmfusion-nonfree-release")
for d in data.get("deployments", [])[:2]:
    pkgs = (d.get("requested-local-packages") or []) + (d.get("local-packages") or [])
    blob = " ".join(str(p) for p in pkgs)
    if all(n in blob for n in needles):
        sys.exit(0)
sys.exit(1)
'
}

if rpmfusion_already_layered; then
  echo "  RPMFusion already layered in staged or booted deployment — skip."
else
  run sudo rpm-ostree install "$RPMFUSION_FREE" "$RPMFUSION_NONFREE"
fi

section "Step 2 — Codec replacement (override + install)"
install_flags=()
for pkg in "${CODEC_INSTALL[@]}"; do
  install_flags+=("--install=$pkg")
done
run sudo rpm-ostree override remove "${OVERRIDE_REMOVE[@]}" "${install_flags[@]}"

section "Step 3 — Media diagnostics + audio baseline + virtualization"
# --allow-inactive: some packages (e.g. mesa-libGLU, pipewire-pulseaudio,
# wireplumber) are already provided by the Silverblue base. Without the
# flag rpm-ostree refuses to layer a request that doesn't change the
# package set. With the flag they're recorded as explicitly requested
# while becoming no-ops if already satisfied — exactly what we want for
# a declarative baseline.
run sudo rpm-ostree install --allow-inactive \
    "${MEDIA_DIAG[@]}" "${AUDIO[@]}" "${VIRT[@]}"

section "Step 4 — Hardware diagnostics + GNOME tools + fonts + creative apps"
run sudo rpm-ostree install --allow-inactive \
    "${HW_DIAG[@]}" "${GNOME_TOOLS[@]}" "${FONTS[@]}" "${CREATIVE_APPS[@]}"

if (( apply )); then
  section "Done"
  echo "A new deployment has been staged. Reboot via GNOME → Power → Restart"
  echo "to enter the new deployment."
  if (( reboot_after )); then
    echo
    echo "Reboot reminder: use the GNOME top-right menu, not 'systemctl reboot'."
    echo "(systemctl reboot is blocked by the GNOME session inhibitor.)"
  fi
else
  section "Dry-run complete"
  echo "Apply with: $0 --apply"
fi
