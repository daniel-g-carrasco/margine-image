#!/usr/bin/env bash
# Apply Margine defaults to Zen Browser (Flatpak `app.zen_browser.zen`).
#
# Best-effort, single concern: set DuckDuckGo as the default search
# engine via `user.js` in the profile directory.
#
# Limitations (by design — keep this script simple):
#   - Requires Zen to have been launched at least once so the profile
#     directory exists. If no profile is found, log and skip.
#   - uBlock Origin (or any extension) is NOT installed automatically.
#     Flatpak isolation makes the Mozilla `policies.json` path messy;
#     user installs manually from addons.mozilla.org in one click.
#
# Usage:
#   configure-zen-browser              # dry-run
#   configure-zen-browser --apply      # actually write user.js
#
# Idempotent: re-running on a profile that already has the DDG pref
# does nothing.

set -euo pipefail

DRY_RUN=1
case "${1:-}" in
  --apply|-a) DRY_RUN=0 ;;
  -h|--help) sed -n '1,30p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
esac

ZEN_HOME="${HOME}/.var/app/app.zen_browser.zen/.zen"

if [[ ! -d "$ZEN_HOME" ]]; then
  echo "Zen profile root not found at $ZEN_HOME"
  echo "→ Launch Zen Browser once, then re-run this script."
  exit 0
fi

# Find profile dir. Zen names them like xxxxxxx.default or
# xxxxxxx.Default (User) — pick the largest by mtime (most recently
# used). If none, bail.
PROFILE=$(ls -1dt "$ZEN_HOME"/*.default* "$ZEN_HOME"/*.Default* 2>/dev/null | head -1 || true)
if [[ -z "$PROFILE" ]]; then
  echo "No Zen profile under $ZEN_HOME — has Zen completed first-run?"
  ls -la "$ZEN_HOME" | head
  exit 0
fi
echo "Profile: $PROFILE"

USER_JS="$PROFILE/user.js"
# The managed-block marker is spelled out literally at every use site
# (awk range, embedded-python regex, heredoc) — a shell variable cannot
# reach the python anyway, so there is deliberately no MARKER var.

prefs=$(cat <<'EOF'
// margine-configure-zen-browser — managed block
// Default search engine: DuckDuckGo (Margine preference).
user_pref("browser.search.defaultenginename", "DuckDuckGo");
user_pref("browser.search.defaultenginename.US", "DuckDuckGo");
user_pref("browser.urlbar.placeholderName", "DuckDuckGo");
user_pref("browser.urlbar.placeholderName.private", "DuckDuckGo");
// Disable Pocket suggestions in URL bar (no Margine value, just noise).
user_pref("browser.urlbar.suggest.pocket", false);
// margine-configure-zen-browser — end managed block
EOF
)

if [[ -f "$USER_JS" ]] && grep -q "margine-configure-zen-browser" "$USER_JS"; then
  echo "user.js already has Margine block — checking if up to date..."
  current=$(awk '/margine-configure-zen-browser — managed block/,/margine-configure-zen-browser — end managed block/' "$USER_JS")
  if [[ "$current" == "$prefs" ]]; then
    echo "  ✓ no change needed"
    exit 0
  fi
  echo "  (Margine block out of date; will rewrite)"
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "  [dry-run] would rewrite block"
    exit 0
  fi
  # Strip the old block, append new
  python3 - "$USER_JS" <<'PY'
import re, sys
path = sys.argv[1]
text = open(path).read()
pattern = r'// margine-configure-zen-browser — managed block.*?// margine-configure-zen-browser — end managed block\n?'
text = re.sub(pattern, '', text, flags=re.DOTALL)
open(path, 'w').write(text.rstrip() + '\n')
PY
fi

if [[ $DRY_RUN -eq 1 ]]; then
  echo "[dry-run] would append managed block to $USER_JS:"
  echo "$prefs" | sed 's/^/  | /'
  echo
  echo "Apply with: $0 --apply"
  exit 0
fi

# Append the managed block. Idempotent thanks to the check above.
{
  [[ -f "$USER_JS" ]] && cat "$USER_JS"
  echo "$prefs"
} > "$USER_JS.new"
mv "$USER_JS.new" "$USER_JS"
echo "  ✓ wrote $USER_JS"
echo
echo "Restart Zen Browser to pick up the new search engine default."
echo "uBlock Origin: install manually from addons.mozilla.org (one click,"
echo "Flatpak isolation makes auto-install via policies.json messy)."
