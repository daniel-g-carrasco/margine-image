[org/gnome/shell/extensions/o-tiling]
# Cosmetic defaults captured from Daniel's reference deployment (2026-06-16):
# tighter gaps, no active-hint border, minimal title-bar chrome.
active-hint=false
# NB: these are uint32 keys — the value MUST carry the `uint32` GVariant type
# tag. A bare `gap-inner=2` is stored as int32 in the dconf db, which mismatches
# the gschema's `u` type, so gsettings silently ignores the default and falls
# back to o-tiling's own (4) — that's why the gaps "weren't applied" on fresh
# installs (user-reported 2026-06-18). Booleans/strings below don't need a tag.
active-hint-border-radius=uint32 14
active-hint-border-width=uint32 3
active-hint-overlay-enabled=false
gap-inner=uint32 2
gap-outer=uint32 1
mouse-cursor-follows-active-window=true
panel-transparency=false
show-close-button=true
show-minimize-maximize-buttons=true
show-title=false
skip-overview=true
smart-gaps=false
snap-to-grid=false
stacking-with-mouse=false
theme-consistency-style='default'
tile-by-default=true
workspace-number-indicator=true
workspace-switcher-style=false

# --- Keybinding conflict resolution (2026-06-14) ---
# o-tiling's UPSTREAM keybinding defaults collide with GNOME-native and
# Margine custom shortcuts. Without these overrides every fresh install
# ships broken (the binding state of an installed system == this file's
# effect): Super+Return never reaches the terminal launcher, Super+T
# silently toggles tiling for the whole session with no clean undo,
# Super+F/Super+S/Super+Alt+arrows shadow fullscreen / quick-settings /
# workspace-switch + overview-shift. GNOME and Margine bindings win;
# o-tiling keeps every feature on a collision-free chord.
#
# Was ['<Super>Return','<Super>KP_Enter'] — ate the custom terminal launcher.
tile-enter=['<Super><Ctrl>Return', '<Super><Ctrl>KP_Enter']
# Was ['<Super>t'] — accidental whole-session tiling toggle (user-reported).
toggle-tiling=['<Super><Shift>t']
# Was ['<Super>f'] — shadowed wm.toggle-fullscreen.
toggle-floating=['<Super><Shift>f']
# Was ['<Super>s'] — shadowed shell.toggle-quick-settings.
toggle-stacking-global=['<Super><Shift>s']
# Focus: keep the Hyprland-parity Super+hjkl, drop the duplicate
# <Super><Alt>arrows that shadowed wm.switch-to-workspace-left/right and
# shell.shift-overview-up/down.
focus-left=['<Super>h']
focus-right=['<Super>l']
focus-up=['<Super>k']
focus-down=['<Super>j']
# Super+arrows previously hit GNOME's gapless built-ins — mutter
# toggle-tiled-left/right (snap to half, no gaps) and wm maximize/unmaximize
# (strips the border) — which ignore o-tiling's layout + gaps (user-reported
# 2026-06-18). Route Super+arrows to o-tiling's GLOBAL move action so they move
# the focused window within the tiled layout WITH the gaps. It MUST be
# tile-move-*-global — that's the action o-tiling registers as a global
# shortcut (system/keybindings.js); tile-swap-* is only handled inside the
# interactive tile mode, so binding it globally is a silent no-op (the bug in
# the first pass). Focus stays on Super+hjkl.
tile-move-left-global=['<Super>Left']
tile-move-right-global=['<Super>Right']
tile-move-up-global=['<Super>Up']
tile-move-down-global=['<Super>Down']

[org/gnome/mutter/keybindings]
# Free Super+Left/Right from GNOME's gapless edge-snap — o-tiling owns window
# placement (Super+arrows now swap tiles, see above).
toggle-tiled-left=@as []
toggle-tiled-right=@as []

[org/gnome/desktop/wm/keybindings]
# Free Super+Up/Down from maximize/unmaximize (they strip o-tiling's gaps and
# borders) — Super+Up/Down now swap tiles up/down.
maximize=@as []
unmaximize=@as []
